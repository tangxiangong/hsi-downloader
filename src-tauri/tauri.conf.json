{
  "productName": "YuShi",
  "version": "0.1.0",
  "identifier": "com.yushi.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src-ui/dist",
    "beforeDevCommand": "cd src-ui && bun run dev",
    "beforeBuildCommand": "cd src-ui && bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600
      },
      {
        "label": "tray",
        "title": "驭时下载概览",
        "width": 430,
        "height": 460,
        "visible": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tangxiangong/YuShi/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
